<line>/* Definição dos componentes */&#010;R1: 470;&#010;R2: 470;&#010;R3: 47000;&#010;C: 100*10^-9;&#010;&#010;/* Função de Transferência H(s) */&#010;H(s) := (-(1/(R1*C))*s) / (s^2 + (2/(R3*C))*s + (R1+R2)/(R1*R2*R3*C^2));&#010;&#010;/* Funções para Magnitude e Fase (em graus) */&#010;mag(f) := float(cabs(at(H(s), s=%i*2*%pi*f)));&#010;fase(f) := float(carg(at(H(s), s=%i*2*%pi*f)) * 180/%pi);&#010;&#010;/* Exemplo de cálculo para 480 Hz */&#010;print(&quot;Magnitude Hz: &quot;, mag(5500));&#010;print(&quot;Fase em 480Hz: &quot;, fase(-127));</line>
</editor>
